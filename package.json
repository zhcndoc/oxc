{
  "name": "website",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vitepress dev",
    "prebuild": "pnpm run sponsors",
    "build": "vitepress build",
    "preview": "vitepress preview",
    "lint": "oxlint --deny-warnings",
    "lint:fix": "pnpm lint --fix && typos -w",
    "fmt": "oxfmt",
    "knip": "knip",
    "sponsors": "degit Boshen/sponsors sponsors --force && node scripts/generate-sponsors.js",
    "prepare": "husky"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "@types/markdown-it-container": "4.0.0",
    "@types/node": "^25.0.3",
    "@voidzero-dev/vitepress-theme": "^4.3.0",
    "degit": "^2.8.4",
    "esbuild": "0.27.3",
    "feed": "^5.1.0",
    "husky": "^9.1.7",
    "knip": "^5.78.0",
    "lint-staged": "16.2.7",
    "markdown-it-container": "^4.0.0",
    "markdown-it-task-lists": "^2.1.1",
    "oxc-minify": "^0.116.0",
    "oxfmt": "^0.36.0",
    "oxlint": "^1.51.0",
    "oxlint-tsgolint": "^0.16.0",
    "typescript": "~5.9.3",
    "vitepress": "2.0.0-alpha.16",
    "vitepress-plugin-group-icons": "^1.7.0",
    "vitepress-plugin-llms": "^1.10.0",
    "vue": "^3.5.26"
  },
  "lint-staged": {
    "*": "oxfmt --no-error-on-unmatched-pattern"
  },
  "packageManager": "pnpm@10.30.2",
  "pnpm": {
    "overrides": {
      "vitepress>vite": "npm:vite@8.0.0-beta.15"
    },
    "onlyBuiltDependencies": [
      "esbuild",
      "vue-demi"
    ]
  }
}
